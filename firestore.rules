rules_version = '2';
// لقمة هنية — moderation + roles. Deploy: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    function recipeCreatorId(r) {
      return r.get('createdBy', r.get('createdByUserId', ''));
    }

    function recipeOwnerRead(r) {
      return signedIn() && recipeCreatorId(r) == request.auth.uid;
    }

    function recipePublic(r) {
      return r.get('visibility', 'public') == 'public'
        && (
          (!('status' in r)
            && (r.get('approved', r.get('isApproved', true)) != false))
          || (r.get('status', '') == 'approved'
            && r.get('approved', r.get('isApproved', false)) == true)
        );
    }

    function recipeReadable(r) {
      return recipePublic(r) || isAdmin() || recipeOwnerRead(r);
    }

    function recipeDoc(recipeId) {
      return get(/databases/$(database)/documents/recipes/$(recipeId)).data;
    }

    match /users/{userId} {
      allow get: if isSelf(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSelf(userId)
        && request.resource.data.get('role', 'user') == 'user';
      allow update: if isSelf(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      allow delete: if isSelf(userId);

      match /{subcollection=**} {
        allow read, write: if isSelf(userId);
      }
    }

    match /recipes/{recipeId} {

      allow get: if recipeReadable(resource.data);
      allow list: if recipeReadable(resource.data);

      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.approved == false
        && request.resource.data.isApproved == false
        && request.resource.data.visibility == 'public'
        && request.resource.data.source == 'user';

      allow update: if isAdmin()
        || (recipeOwnerRead(resource.data)
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending'
          && request.resource.data.approved == false
          && request.resource.data.isApproved == false
          && recipeCreatorId(request.resource.data) == request.auth.uid
          && recipeCreatorId(request.resource.data) == recipeCreatorId(resource.data)
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['approved', 'isApproved', 'status', 'visibility',
              'rejectedReason', 'rejectedAt', 'rejectedBy',
              'approvedBy', 'approvedAt']));

      allow delete: if isAdmin()
        || (recipeOwnerRead(resource.data) && resource.data.status == 'pending');

      match /ratings/{ratingUserId} {
        allow read: if recipePublic(recipeDoc(recipeId))
          || isAdmin()
          || recipeOwnerRead(recipeDoc(recipeId));

        allow create, update: if signedIn()
          && recipePublic(recipeDoc(recipeId))
          && ratingUserId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.recipeId == recipeId
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;

        allow delete: if signedIn() && ratingUserId == request.auth.uid;
      }
    }

    match /public_stats/{document=**} {
      allow read: if true;
      allow write: if signedIn();
    }
  }
}
