rules_version = '2';
// لقمة هنية — development-safe rules (MVP). Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function approvedRecipeRead() {
      return !('approved' in resource.data) || resource.data.approved == true;
    }

    // Own profile + subcollections (favorites, meal_plans, meal_weeks, …)
    match /users/{userId} {
      allow read, write: if isSelf(userId);

      match /{subcollection=**} {
        allow read, write: if isSelf(userId);
      }
    }

    match /recipes/{recipeId} {
      // Public catalogue: approved (or legacy docs without `approved`)
      allow get, list: if approvedRecipeRead();

      // Authenticated users can publish recipes they created
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;

      // MVP: any signed-in client may update (rating aggregates + owner edits).
      // Replace with field masks / Cloud Functions before production.
      allow update: if signedIn();

      allow delete: if signedIn()
        && (!('createdBy' in resource.data)
          || resource.data.createdBy == request.auth.uid);

      // Public ratings: anyone can read for aggregates; only author can write own doc
      match /ratings/{ratingUserId} {
        allow read: if true;

        allow create, update: if signedIn()
          && ratingUserId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.recipeId == recipeId
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;

        allow delete: if signedIn() && ratingUserId == request.auth.uid;
      }
    }

    match /public_stats/{document=**} {
      allow read: if true;
      allow write: if signedIn();
    }
  }
}
